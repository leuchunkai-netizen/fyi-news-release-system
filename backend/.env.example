# Backend-only secrets (copy to backend/.env)
PORT=10000

# --- Supabase (DB + auth on client; service role for server-side API only) ---
# Required for: saving AI summary to articles.*, submit-review, admin DB updates.
# Must be the service_role key from Supabase Dashboard → Settings → API (not the anon key).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Same value as frontend VITE_SUPABASE_ANON_KEY — required for POST /api/articles/submit-review (JWT verification)
SUPABASE_ANON_KEY=

# --- Auto-publish after submit-for-review (fact-check must pass) ---
AUTO_APPROVE_MIN_CONFIDENCE=70
AUTO_APPROVE_VERDICTS=VERIFIED,UNCERTAIN

# --- OpenAI: fact-check / reasoning (gpt-4o-mini) + optional claim fallback & embeddings ---
OPENAI_API_KEY=
OPENAI_FACTCHECK_MODEL=gpt-4o-mini
OPENAI_CLAIM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Hugging Face: preferred for claim extraction / summarization (Inference API token) ---
HF_TOKEN=
# HUGGINGFACE_API_KEY=   # alias for HF_TOKEN
HUGGINGFACE_CLAIM_MODEL=meta-llama/Llama-3.2-3B-Instruct
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Submission gates (POST /api/articles/factcheck) ---
# MIN_ARTICLE_CHARS=80
# MAX_ARTICLE_CHARS=120000

# --- NewsData.io: evidence from trusted outlets (default BBC, CNA, Reuters) ---
# https://newsdata.io/dashboard · https://newsdata.io/documentation
NEWSDATA_API_KEY=
# NEWSDATA_LANGUAGE=en
# Comma-separated hostnames (no https):
# EVIDENCE_DOMAINS=bbc.co.uk,bbc.com,channelnewsasia.com,reuters.com
# NEWSDATA_PAGE_SIZE=10
# NEWSDATA_MAX_PAGES=4
# NEWSDATA_EVIDENCE_POOL=24
# NEWSDATA_PER_CLAIM_MAX=4
# If NewsData returns articles but none from EVIDENCE_DOMAINS (common for entertainment topics), use those results anyway (default true). Set false for placeholders only.
# EVIDENCE_ALLOW_UNFILTERED_FALLBACK=true

# --- Fact-check reasoning depth ---
# Number of evidence snippets passed to OpenAI for claim verification (default 8, minimum 3)
# FACTCHECK_EVIDENCE_MAX=8

# --- pgvector (Supabase): run backend/db/pgvector.sql, then enable RPC name below ---
# Uses OpenAI 1536-d embeddings by default; set PGVECTOR_EMBEDDING_DIM if you change the SQL.
# PGVECTOR_MATCH_RPC=match_document_chunks
# PGVECTOR_MATCH_COUNT=6
# PGVECTOR_EMBEDDING_DIM=1536

# --- Rate limits (optional overrides) ---
# API_RATE_LIMIT_MAX=200
# API_HEAVY_RATE_LIMIT_MAX=30
