# Supabase (get these from Project Settings > API in Supabase Dashboard)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: call the Express API directly (bypasses Vite proxy). Use when POST /api/* returns 404 while Vite runs on 5173.
# Backend must run on the same port (default 10000) with CORS enabled (see backend/server.js).
# VITE_API_URL=http://localhost:10000

# Optional: for admin/expert actions from a backend (service role key - never expose in frontend)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: Stripe publishable key (test mode, for UI/debug visibility only)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Backend AI pipeline (backend/.env only; never expose in VITE_*)
# Prefer backend/.env — see backend/.env.example (NewsData.io, Hugging Face, OpenAI, pgvector).
# OPENAI_API_KEY=your_key_here
# HF_TOKEN=your_huggingface_token_here
# NEWSDATA_API_KEY=your_newsdata_io_key_here
